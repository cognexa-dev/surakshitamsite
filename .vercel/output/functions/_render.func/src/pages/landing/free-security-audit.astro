---
import LandingPageLayout from "../../layouts/LandingPageLayout.astro";
import LeadForm from "../../components/shared/LeadForm.astro";
import FAQ from "../../components/shared/FAQ.astro";
import { siteConfig } from "../../data/site";
import { cybersecurityFaqs } from "../../data/faqs";

const site = siteConfig.surakshitam;
---

<LandingPageLayout
  title="Free Security Audit — Surakshitam"
  description="Get a free security audit from Surakshitam. We identify your highest-risk areas and provide practical recommendations."
>
  <section class="py-12 md:py-20 bg-[#0a0f1a]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-semibold text-red-400 uppercase tracking-widest mb-3">Free Offer</p>
          <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-5 text-balance">
            Free Security Audit for Your Organization
          </h1>
          <p class="text-slate-300 leading-relaxed mb-6">
            We review your current security setup — firewall, network, web applications, and access controls — and tell you exactly where your highest risks are. No cost, no commitment.
          </p>
          <ul class="space-y-3 mb-8">
            {["Network and firewall review", "Identification of high-risk vulnerabilities", "Written findings summary", "Practical next-step recommendations"].map((b) => (
              <li class="flex items-start gap-3 text-slate-300 text-sm">
                <span class="text-emerald-400 mt-0.5 shrink-0">✓</span>{b}
              </li>
            ))}
          </ul>
          <div class="flex flex-col sm:flex-row gap-3 text-sm">
            <a href={`tel:${site.phoneRaw}`} class="flex items-center gap-2 text-slate-400 hover:text-white" data-event="phone_click" data-location="landing-audit">📞 {site.phone}</a>
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-slate-400 hover:text-white" data-event="whatsapp_click" data-location="landing-audit">💬 WhatsApp</a>
          </div>
        </div>
        <div>
          <LeadForm
            title="Request Free Security Audit"
            subtitle="We will get back to you within 24 hours."
            services={["Full Security Audit", "Managed Firewall Assessment", "Vulnerability Scan", "Penetration Test", "WAF Assessment"]}
            action="/api/lead"
            thankYouUrl="/thank-you/"
            variant="dark"
          />
        </div>
      </div>
    </div>
  </section>
  <FAQ items={cybersecurityFaqs.slice(0, 3)} variant="dark" title="Common Questions" />
</LandingPageLayout>
