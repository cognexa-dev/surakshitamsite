---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
  variant?: "light" | "dark";
}

const { items, title = "Frequently Asked Questions", variant = "light" } = Astro.props;

const isDark = variant === "dark";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class:list={["py-16", isDark ? "bg-slate-900" : "bg-slate-50"]}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2
      class:list={[
        "text-2xl md:text-3xl font-bold mb-10 text-center",
        isDark ? "text-white" : "text-slate-900",
      ]}
    >
      {title}
    </h2>
    <div class="space-y-4">
      {
        items.map((item, i) => (
          <details
            class:list={[
              "group rounded-xl border p-5 cursor-pointer",
              isDark
                ? "border-slate-700 bg-slate-800"
                : "border-slate-200 bg-white",
            ]}
          >
            <summary class:list={["flex items-center justify-between gap-4 font-semibold list-none select-none", isDark ? "text-white" : "text-slate-900"]}>
              <span>{item.question}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-5 h-5 shrink-0 transition-transform group-open:rotate-180"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <p
              class:list={[
                "mt-3 text-sm leading-relaxed",
                isDark ? "text-slate-400" : "text-slate-600",
              ]}
            >
              {item.answer}
            </p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
