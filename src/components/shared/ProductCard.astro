---
interface Props {
  name: string;
  title: string;
  summary: string;
  href: string;
  cta?: string;
  accentColor?: string;
  variant?: "light" | "dark";
}

const {
  name,
  title,
  summary,
  href,
  cta = "Learn More",
  accentColor = "#3b82f6",
  variant = "dark",
} = Astro.props;

const isDark = variant === "dark";
---

<article
  class:list={[
    "group rounded-2xl border-l-4 p-6 flex flex-col transition-all hover:shadow-lg",
    isDark
      ? "bg-slate-800 border-slate-700 hover:bg-slate-750"
      : "bg-white border-slate-200 hover:shadow-md",
  ]}
  style={`border-left-color: ${accentColor}`}
>
  <div class="mb-3">
    <span
      class="text-xs font-bold uppercase tracking-widest"
      style={`color: ${accentColor}`}
    >
      {name}
    </span>
    <h3 class:list={["text-lg font-bold mt-0.5", isDark ? "text-white" : "text-slate-900"]}>
      {title}
    </h3>
  </div>
  <p class:list={["text-sm leading-relaxed flex-1", isDark ? "text-slate-400" : "text-slate-600"]}>
    {summary}
  </p>
  <a
    href={href}
    class:list={[
      "mt-5 inline-flex items-center gap-1 text-sm font-semibold transition-colors",
    ]}
    style={`color: ${accentColor}`}
    data-event="service_card_click"
    data-location="card"
    data-service={name}
  >
    {cta}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="w-4 h-4 transition-transform group-hover:translate-x-0.5"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
        clip-rule="evenodd"
      />
    </svg>
  </a>
</article>
